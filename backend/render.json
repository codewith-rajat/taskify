{
  "buildCommand": "npm install",
  "startCommand": "npm start",
  "envVars": [
    {
      "key": "DB_USER",
      "value": "your_db_user"
    },
    {
      "key": "DB_PASSWORD",
      "value": "your_db_password"
    },
    {
      "key": "DB_HOST",
      "value": "your_db_host"
    },
    {
      "key": "DB_NAME",
      "value": "project_management"
    },
    {
      "key": "JWT_SECRET",
      "value": "your-secret-key-here"
    },
    {
      "key": "PORT",
      "value": "5000"
    }
  ]
}
