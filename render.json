{
  "name": "taskify-backend",
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "envVars": [
    {
      "key": "DB_USER",
      "value": "postgres"
    },
    {
      "key": "DB_PASSWORD",
      "value": "your_db_password"
    },
    {
      "key": "DB_HOST",
      "value": "your_db_host"
    },
    {
      "key": "DB_PORT",
      "value": "5432"
    },
    {
      "key": "DB_NAME",
      "value": "postgres"
    },
    {
      "key": "JWT_SECRET",
      "value": "your-secret-key-here"
    },
    {
      "key": "PORT",
      "value": "10000"
    },
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "FRONTEND_URL",
      "value": "https://taskify-frontend.vercel.app"
    }
  ]
}
